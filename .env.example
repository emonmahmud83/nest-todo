# Supabase Database URL
# Copy the "Transaction pooler" string from Supabase (Settings > Database > Connection pooler)
DATABASE_URL="postgresql://postgres.[your-project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (used for Prisma migrations)
# Copy the "Session" string from Supabase (Settings > Database > Connection string > URI)
DIRECT_URL="postgresql://postgres.[your-project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:5432/postgres"

PORT=3000
